{
  "manifest_version": 3,
  "name": "OmniStitch MVP",
  "version": "0.1.0",
  "description": "One-click: jump to ChatGPT/Kimi/DeepSeek/Gemini and auto-send prompt with current page URL.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "alarms",
    "webRequest"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Send to AI"
  },
  "commands": {
    "send-to-chatgpt": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Send active page URL to configured AI agent"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://chat.deepseek.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "agents/capture/capture-common.js",
        "agents/capture/chatgpt-capture.js",
        "agents/capture/kimi-capture.js",
        "agents/capture/deepseek-capture.js",
        "agents/capture/gemini-capture.js",
        "response-capture-main.js"
      ],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://chat.deepseek.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "agents/agent-common.js",
        "agents/chatgpt-agent.js",
        "agents/kimi-agent.js",
        "agents/deepseek-agent.js",
        "agents/gemini-agent.js",
        "agents/agent-site-adapters.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
